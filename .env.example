# Canonical env key order for this repo.
# Keep local .env in this same order and add new keys here first.
#
# Classification:
# - Boot-time: resolved before process startup; changing requires restart
# - Runtime-configurable: candidates for the future Operator UX config surface
# - Secrets: keep out of the UI in plaintext; rotate through a dedicated secret flow
# - Dev / E2E: local verification helpers, not part of normal production operation

# -- Boot-Time: Infrastructure, Storage, and Paths ----------------------------
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.10
OPENCLAW_HOST_PORT=3578
POSTGRES_DB=reddwarf
POSTGRES_USER=reddwarf
POSTGRES_PASSWORD=reddwarf
POSTGRES_HOST_PORT=55532
DATABASE_URL=postgresql://reddwarf:reddwarf@postgres:5432/reddwarf
HOST_DATABASE_URL=postgresql://reddwarf:reddwarf@127.0.0.1:55532/reddwarf
REDDWARF_POLICY_SOURCE_ROOT=../../
REDDWARF_POLICY_ROOT=/opt/reddwarf
REDDWARF_WORKSPACE_ROOT=/var/lib/reddwarf/workspaces
REDDWARF_EVIDENCE_ROOT=/var/lib/reddwarf/evidence
REDDWARF_HOST_WORKSPACE_ROOT=runtime-data/workspaces
REDDWARF_HOST_EVIDENCE_ROOT=runtime-data/evidence
REDDWARF_POLICY_PACKAGE_OUTPUT_ROOT=artifacts/policy-packs
REDDWARF_OPENCLAW_WORKSPACE_ROOT=runtime-data/openclaw-workspaces
REDDWARF_OPENCLAW_CONFIG_PATH=runtime-data/openclaw-home/openclaw.json
REDDWARF_OPENCLAW_OPERATOR_API_URL=http://host.docker.internal:8080
REDDWARF_OPENCLAW_TRUSTED_AUTOMATION=false

# -- Runtime-Configurable: OpenClaw Features ---------------------------------
# Model provider for generated OpenClaw agent bindings.
# Allowed values: anthropic | openai | openai-codex
# - anthropic: direct Anthropic API (requires ANTHROPIC_API_KEY)
# - openai: direct OpenAI API (requires OPENAI_API_KEY, per-token billing)
# - openai-codex: ChatGPT Pro/Plus subscription via OpenAI Codex OAuth (flat-rate)
REDDWARF_MODEL_PROVIDER=anthropic
# Enable cross-provider model failover chains in generated openclaw.json.
# When true, each agent gets a modelFallback pointing to the alternate provider.
# Both ANTHROPIC_API_KEY and OPENAI_API_KEY must be set for failover to activate.
# NOTE: when REDDWARF_MODEL_PROVIDER=openai-codex the failover target is the
# direct OpenAI API, which burns per-token credits. Keep this false for Codex.
REDDWARF_MODEL_FAILOVER_ENABLED=false
REDDWARF_OPENCLAW_BROWSER_ENABLED=true

# -- OpenClaw compaction and context limits (agents.defaults) ----------------
# Emits agents.defaults.compaction when mode is set. Recommended posture for
# long-running RedDwarf sessions: mode=safeguard with identifier_policy=strict
# so Project Mode TicketSpec IDs survive summarisation.
# Allowed: default | safeguard
# REDDWARF_OPENCLAW_COMPACTION_MODE=
# Allowed: strict | custom | off
# REDDWARF_OPENCLAW_COMPACTION_IDENTIFIER_POLICY=
# REDDWARF_OPENCLAW_COMPACTION_TIMEOUT_SECONDS=
# REDDWARF_OPENCLAW_COMPACTION_NOTIFY_USER=
# REDDWARF_OPENCLAW_COMPACTION_MEMORY_FLUSH_ENABLED=
# REDDWARF_OPENCLAW_COMPACTION_MEMORY_FLUSH_SOFT_THRESHOLD_TOKENS=

# Emits agents.defaults.contextLimits. Caps memory-read, tool-result, and
# post-compaction character counts so a single large validation output can't
# blow the context window.
# REDDWARF_OPENCLAW_CONTEXT_MEMORY_GET_MAX_CHARS=12000
# REDDWARF_OPENCLAW_CONTEXT_TOOL_RESULT_MAX_CHARS=16000
# REDDWARF_OPENCLAW_CONTEXT_POST_COMPACTION_MAX_CHARS=1800

# Emits agents.defaults.bootstrapMaxChars / bootstrapTotalMaxChars /
# bootstrapPromptTruncationWarning. RedDwarf owns its own bootstrap content;
# these only affect gateway-side truncation warnings.
# REDDWARF_OPENCLAW_BOOTSTRAP_MAX_CHARS=20000
# REDDWARF_OPENCLAW_BOOTSTRAP_TOTAL_MAX_CHARS=150000
# Allowed: off | once | always
# REDDWARF_OPENCLAW_BOOTSTRAP_PROMPT_TRUNCATION_WARNING=once

# -- OpenClaw loop detection (tools.loopDetection) ---------------------------
# Gateway-level watchdog that warns or aborts when agents repeat the same tool
# call, poll without progress, or ping-pong between two responses.
# Set ENABLED=true to emit the block; individual detectors default on inside
# the gateway once the feature is turned on unless explicitly set to false.
REDDWARF_OPENCLAW_LOOP_DETECTION_ENABLED=false
# REDDWARF_OPENCLAW_LOOP_DETECTION_WARNING_THRESHOLD=10
# REDDWARF_OPENCLAW_LOOP_DETECTION_CRITICAL_THRESHOLD=20
# REDDWARF_OPENCLAW_LOOP_DETECTION_GENERIC_REPEAT=true
# REDDWARF_OPENCLAW_LOOP_DETECTION_KNOWN_POLL_NO_PROGRESS=true
# REDDWARF_OPENCLAW_LOOP_DETECTION_PING_PONG=true
# Enable structured execution item persistence from OpenClaw session transcripts.
# Requires OpenClaw >= v2026.4.5. Emits AGENT_PROGRESS_ITEM run events per completed step.
REDDWARF_EXECUTION_ITEMS_ENABLED=false
# Enable the before_tool_call approval hook in the reddwarf-operator plugin.
# Requires OpenClaw >= v2026.3.28. Intercepts file writes against denied paths and
# routes sensitive operations through the RedDwarf operator API for approval.
REDDWARF_PLUGIN_APPROVAL_HOOK_ENABLED=false
# Enable agent-to-agent messaging (sessions_send) between OpenClaw roster agents.
# When false (default), agents cannot send unsolicited messages to other agents.
REDDWARF_OPENCLAW_AGENT_TO_AGENT_ENABLED=false
# Enable OpenClaw Task Flow mirrored mode for project ticket pipelines.
# Requires OpenClaw >= v2026.4.2. Creates a durable Task Flow on project approval;
# advanceProjectTicket signals flow state transitions instead of raw dispatches.
REDDWARF_TASKFLOW_ENABLED=false
# Use ACPX embedded session binding for dispatch instead of POST /hooks/agent.
# Provides streaming progress events, real sessionId, and graceful cancellation.
# Requires OpenClaw >= v2026.4.5.
REDDWARF_ACPX_DISPATCH_ENABLED=false
# Enable ClawHub skill publishing and dynamic skill discovery for Holly during planning.
# Requires OpenClaw >= v2026.4.5. Only skills from verified publishers or the curated
# allowlist (reddwarf/*, anthropic/*) are installed. Discovered skills are recorded as
# evidence metadata.
REDDWARF_CLAWHUB_ENABLED=false
# Comma-separated list of ClawHub publisher glob patterns allowed for skill installation.
# Defaults to reddwarf/*,anthropic/* when not set.
REDDWARF_CLAWHUB_ALLOWED_PUBLISHERS=reddwarf/*,anthropic/*
# Capture OpenClaw dreaming session learnings as repo-scoped memory records.
# After each agent session, RedDwarf parses dreams.md from the workspace and
# saves structured observations as memory_records (scope=repo, provenance=agent_observed).
# Requires OpenClaw >= v2026.4.5 and the 0016_dreaming_memory_enums.sql migration.
REDDWARF_DREAMING_MEMORY_ENABLED=false
REDDWARF_OPENCLAW_DISCORD_ENABLED=false
REDDWARF_OPENCLAW_DISCORD_DM_POLICY=pairing
REDDWARF_OPENCLAW_DISCORD_GROUP_POLICY=allowlist
REDDWARF_OPENCLAW_DISCORD_GUILD_IDS=
REDDWARF_OPENCLAW_DISCORD_REQUIRE_MENTION=true
REDDWARF_OPENCLAW_DISCORD_NOTIFICATIONS_ENABLED=false
REDDWARF_OPENCLAW_DISCORD_STREAMING=partial
REDDWARF_OPENCLAW_DISCORD_HISTORY_LIMIT=24
REDDWARF_OPENCLAW_DISCORD_AUTO_PRESENCE_ENABLED=true
REDDWARF_OPENCLAW_DISCORD_AUTO_PRESENCE_INTERVAL_MS=
REDDWARF_OPENCLAW_DISCORD_AUTO_PRESENCE_MIN_UPDATE_INTERVAL_MS=
REDDWARF_OPENCLAW_DISCORD_AUTO_PRESENCE_HEALTHY_TEXT=
REDDWARF_OPENCLAW_DISCORD_AUTO_PRESENCE_DEGRADED_TEXT=
REDDWARF_OPENCLAW_DISCORD_AUTO_PRESENCE_EXHAUSTED_TEXT=
REDDWARF_OPENCLAW_DISCORD_EXEC_APPROVALS_ENABLED=false
REDDWARF_OPENCLAW_DISCORD_APPROVER_IDS=
REDDWARF_OPENCLAW_DISCORD_EXEC_APPROVAL_TARGET=channel
REDDWARF_OPENCLAW_DISCORD_ACCENT_COLOR=#d7263d

# -- Runtime-Configurable: Webhook and Polling --------------------------------
# GitHub webhook secret for HMAC-SHA256 verification. When set, the webhook
# receiver is activated and (in auto mode) polling is disabled.
# Generate with: openssl rand -hex 32
# REDDWARF_WEBHOOK_SECRET=
# Webhook route path (default: /webhooks/github)
# REDDWARF_WEBHOOK_PATH=/webhooks/github
# Polling mode: auto | always | never (default: auto)
# auto = poll when webhook secret is not set; disable polling when it is
# always = always poll regardless of webhook config
# never = never poll regardless of webhook config
REDDWARF_POLL_MODE=auto

# -- Runtime-Configurable: Polling, Dispatch, and API -------------------------
REDDWARF_POLL_REPOS=
REDDWARF_POLL_INTERVAL_MS=30000
# Per-repo polling timeout in ms (default 60000 = 60s). A slow repo cannot starve other repos.
REDDWARF_POLL_PER_REPO_TIMEOUT_MS=60000
REDDWARF_DISPATCH_INTERVAL_MS=15000
# Periodic stale-run sweep interval in ms (default 300000 = 5 min). Set REDDWARF_PERIODIC_SWEEP_ENABLED=false to disable.
REDDWARF_PERIODIC_SWEEP_INTERVAL_MS=300000
REDDWARF_PERIODIC_SWEEP_ENABLED=true

# -- Runtime-Configurable: runtime-data cleanup on boot -----------------------
# Prune OpenClaw config backups (openclaw.json.bak*, .clobbered.*) and stale
# openclaw-home.backup.<timestamp>/ directories older than N days during
# `pnpm start` / `pnpm run setup`. These are artifacts the OpenClaw gateway
# creates and no live code reads — they grow without bound unless pruned.
REDDWARF_OPENCLAW_BACKUP_CLEANUP_ENABLED=true
REDDWARF_OPENCLAW_BACKUP_MAX_AGE_DAYS=14

# Enforce a retention policy on runtime-data/evidence/. Evidence directories
# older than N days are removed on boot. Evidence files are referenced from
# the evidence_records table in Postgres; rows may outlive files if this
# threshold is smaller than your audit needs. Pair with cleanup-evidence.mjs
# for ad-hoc pruning outside the boot path.
REDDWARF_EVIDENCE_BOOT_CLEANUP_ENABLED=true
REDDWARF_EVIDENCE_MAX_AGE_DAYS=14
REDDWARF_API_PORT=8080
# Bind interface for the operator API. Default 127.0.0.1 is correct for
# dev machines (Docker Desktop handles host.docker.internal → loopback
# for you). On a Linux VPS running Docker CE, set to 0.0.0.0 so containers
# on the host can reach the operator API via the docker-bridge gateway
# (host.docker.internal resolves to that bridge, not 127.0.0.1). The
# public firewall should still block :8080 externally; the Caddy layer
# fronts public traffic on 443.
# REDDWARF_API_HOST=127.0.0.1
REDDWARF_DASHBOARD_PORT=5173
REDDWARF_API_URL=http://127.0.0.1:8080
# Origin of the dashboard dev server (default: http://localhost:5173)
# REDDWARF_DASHBOARD_ORIGIN=http://localhost:5173
REDDWARF_LOG_LEVEL=info
REDDWARF_SKIP_DASHBOARD=false
REDDWARF_SKIP_OPENCLAW=false
REDDWARF_DRY_RUN=false

# -- Runtime-Configurable: Pool and Guardrails --------------------------------
# Minimum free disk space (MB) before workspace/evidence writes. Default: 500.
# REDDWARF_MIN_DISK_FREE_MB=500
REDDWARF_DB_POOL_MAX=10
REDDWARF_DB_POOL_CONNECTION_TIMEOUT_MS=5000
REDDWARF_DB_POOL_IDLE_TIMEOUT_MS=30000
REDDWARF_DB_POOL_QUERY_TIMEOUT_MS=15000
REDDWARF_DB_POOL_STATEMENT_TIMEOUT_MS=15000
REDDWARF_DB_POOL_MAX_LIFETIME_SECONDS=300
REDDWARF_MAX_RETRIES_ARCHITECT=2
REDDWARF_MAX_RETRIES_DEVELOPER=1
REDDWARF_MAX_RETRIES_VALIDATOR=1
REDDWARF_MAX_RETRIES_REVIEWER=1
REDDWARF_MAX_RETRIES_SCM=1
REDDWARF_TOKEN_BUDGET_ARCHITECT=80000
REDDWARF_TOKEN_BUDGET_DEVELOPER=120000
REDDWARF_TOKEN_BUDGET_VALIDATOR=40000
REDDWARF_TOKEN_BUDGET_REVIEWER=60000
REDDWARF_TOKEN_BUDGET_SCM=40000
REDDWARF_TOKEN_BUDGET_OVERAGE_ACTION=warn

# -- Secrets: API Keys and Operator Credentials --------------------------------
# GitHub personal access token for issue intake and SCM operations
GITHUB_TOKEN=ghp_your_token_here
# Anthropic API key, required when REDDWARF_MODEL_PROVIDER=anthropic (or when
# failover is enabled and anthropic is the fallback target). NOT injected into
# the OpenClaw container when provider=openai-codex and failover is off — the
# startup flow scopes container env to only the active-provider key (F-157).
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OpenAI API key, required when REDDWARF_MODEL_PROVIDER=openai (or when
# failover is enabled and openai is the fallback target). NOT injected into
# the OpenClaw container when provider=openai-codex and failover is off —
# Codex uses OAuth profiles at runtime-data/workspaces/.agents/<role>/agent/
# auth-profiles.json, not this key.
OPENAI_API_KEY=sk-your_openai_key_here
# OpenClaw webhook hook token - treat as a privileged secret (full-trust ingress)
OPENCLAW_HOOK_TOKEN=replace_with_a_long_random_hook_token
# OpenClaw gateway base URL for HTTP dispatch
OPENCLAW_BASE_URL=http://localhost:3578
# OpenClaw gateway token - used by the Control UI on port 3578
OPENCLAW_GATEWAY_TOKEN=replace_with_a_long_random_gateway_token
# OpenClaw Discord bot token - used when native Discord channels are enabled
OPENCLAW_DISCORD_BOT_TOKEN=replace_with_a_discord_bot_token
# RedDwarf operator API token - required for approvals, runs, blocked, snapshot, and dispatch routes
REDDWARF_OPERATOR_TOKEN=replace_with_a_long_random_operator_token

# -- Project Mode: GitHub Issues Adapter ----------------------------------------
# Enable the GitHub Issues adapter for project mode sub-issue creation.
# When false (default), the adapter throws V1MutationDisabledError.
REDDWARF_GITHUB_ISSUES_ENABLED=false
# Optional default GitHub repository for sub-issue creation (owner/name format).
# Project approval normally uses each ProjectSpec.sourceRepo, so this is only a
# fallback for direct adapter calls that do not pass a repo.
# GITHUB_REPO=owner/repo

# -- Project Mode: External Reachability ---------------------------------------
# Public URL of the operator API, used by GitHub Actions workflows to call
# POST /projects/advance on PR merge. When Tailscale Funnel is enabled,
# this will be a https://<machine-name>.<tailnet>.ts.net:<port> URL.
# Leave blank if GitHub Actions reachability is not yet configured.
# REDDWARF_OPERATOR_API_URL=
# Clarification loop timeout (ms). When Holly requests clarification and no
# answer arrives within this window, the planning session escalates to the
# operator API for manual resolution. Default: 30 minutes.
# REDDWARF_CLARIFICATION_TIMEOUT_MS=1800000

# -- Dev / E2E ----------------------------------------------------------------
E2E_TARGET_REPO=owner/repo
E2E_USE_OPENCLAW=false
E2E_CLEANUP=false
