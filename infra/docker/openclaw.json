{
  "gateway": {
    "bind": "lan",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:3578",
        "http://localhost:3578"
      ]
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "reddwarf-coordinator",
        "default": true,
        "name": "RedDwarf Coordinator",
        "workspace": "/opt/reddwarf/agents/openclaw/rimmer",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-coordinator/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "minimal",
          "allow": [
            "group:fs",
            "group:sessions",
            "group:memory",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging",
            "group:nodes"
          ]
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "ro"
        }
      },
      {
        "id": "reddwarf-analyst",
        "name": "RedDwarf Analyst",
        "workspace": "/opt/reddwarf/agents/openclaw/holly",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-analyst/agent",
        "model": "anthropic/claude-opus-4-6",
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:memory",
            "group:web",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "ro"
        }
      },
      {
        "id": "reddwarf-validator",
        "name": "RedDwarf Validator",
        "workspace": "/opt/reddwarf/agents/openclaw/kryten",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-validator/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:memory",
            "group:openclaw"
          ],
          "deny": [
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw"
        }
      },
      {
        "id": "reddwarf-developer",
        "name": "RedDwarf Developer",
        "workspace": "/opt/reddwarf/agents/openclaw/lister",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-developer/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:memory",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw"
        }
      }
    ]
  }
}
