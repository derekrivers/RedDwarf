{
  "name": "@reddwarf/root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "reddwarf": "./scripts/reddwarf.mjs"
  },
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:postgres": "vitest run tests/postgres.test.ts",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/apply-sql-migrations.mjs",
    "compose:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "compose:up:openclaw": "docker compose -f infra/docker/docker-compose.yml --profile openclaw up -d",
    "compose:down": "docker compose -f infra/docker/docker-compose.yml down",
    "validate:policy-pack": "node scripts/validate-policy-pack.mjs",
    "verify:postgres": "corepack pnpm build && node scripts/verify-postgres-pipeline.mjs",
    "workspace:materialize": "corepack pnpm build && node scripts/materialize-openclaw-context.mjs",
    "verify:context": "corepack pnpm build && node scripts/verify-openclaw-context.mjs",
    "verify:observability": "corepack pnpm build && node scripts/verify-observability.mjs",
    "verify:integrations": "corepack pnpm build && node scripts/verify-integrations.mjs",
    "verify:memory": "corepack pnpm build && node scripts/verify-memory.mjs",
    "verify:concurrency": "corepack pnpm build && node scripts/verify-concurrency.mjs",
    "package:policy-pack": "corepack pnpm build && node scripts/package-policy-pack.mjs",
    "verify:package": "corepack pnpm build && node scripts/verify-packaged-policy-pack.mjs",
    "workspace:destroy": "corepack pnpm build && node scripts/destroy-openclaw-workspace.mjs",
    "verify:workspace-manager": "corepack pnpm build && node scripts/verify-workspace-manager.mjs",
    "verify:approvals": "corepack pnpm build && node scripts/verify-approvals.mjs",
    "verify:development": "corepack pnpm build && node scripts/verify-development.mjs",
    "verify:validation": "corepack pnpm build && node scripts/verify-validation.mjs",
    "verify:secrets": "corepack pnpm build && node scripts/verify-secrets.mjs",
    "verify:scm": "corepack pnpm build && node scripts/verify-scm.mjs",
    "verify:evidence": "corepack pnpm build && node scripts/verify-evidence.mjs",
    "verify:recovery": "corepack pnpm build && node scripts/verify-recovery.mjs",
    "verify:operator-api": "corepack pnpm build && node scripts/verify-operator-api.mjs",
    "verify:operator-mcp": "corepack pnpm build && node scripts/verify-operator-mcp.mjs",
    "verify:report-cli": "corepack pnpm build && node scripts/verify-report-cli.mjs",
    "verify:submit-cli": "corepack pnpm build && node scripts/verify-submit-cli.mjs",
    "verify:knowledge-ingestion": "corepack pnpm build && node scripts/verify-knowledge-ingestion.mjs",
    "verify:bootstrap-alignment": "corepack pnpm build && node scripts/verify-bootstrap-alignment.mjs",
    "verify:all": "corepack pnpm build && node scripts/verify-all.mjs",
    "setup": "corepack pnpm build && node scripts/setup.mjs",
    "cleanup:evidence": "node scripts/cleanup-evidence.mjs",
    "query:evidence": "node scripts/query-evidence.mjs",
    "reddwarf:report": "node scripts/reddwarf.mjs report",
    "operator:api": "node scripts/start-operator-api.mjs",
    "generate:openclaw-config": "corepack pnpm build && node scripts/generate-openclaw-config.mjs",
    "start": "corepack pnpm build && node scripts/start-stack.mjs",
    "teardown": "node scripts/teardown.mjs",
    "e2e": "corepack pnpm build && node scripts/e2e-integration.mjs",
    "e2e:cleanup": "node scripts/e2e-cleanup.mjs",
    "e2e:chaos:kill-recover": "corepack pnpm build && node scripts/e2e-chaos-kill-recover.mjs",
    "e2e:chaos:pg-restart": "corepack pnpm build && node scripts/e2e-chaos-postgres-restart.mjs",
    "e2e:chaos:openclaw-kill": "corepack pnpm build && node scripts/e2e-chaos-openclaw-kill.mjs",
    "e2e:chaos": "corepack pnpm e2e:chaos:kill-recover && corepack pnpm e2e:chaos:pg-restart && corepack pnpm e2e:chaos:openclaw-kill",
    "loadtest": "k6 run tests/k6-operator-api.js",
    "chaos:run": "node scripts/chaos-run.mjs",
    "cleanup:approvals": "node scripts/cleanup-approvals.mjs"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "drizzle-orm": "^0.40.0",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  }
}
