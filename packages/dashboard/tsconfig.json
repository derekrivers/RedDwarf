{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist/types",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "paths": {
      "@reddwarf/contracts": ["../contracts/dist/index.d.ts"],
      "@reddwarf/execution-plane": ["../execution-plane/dist/index.d.ts"],
      "@reddwarf/execution-plane/dashboard-agent-roles": [
        "../execution-plane/dist/dashboard-agent-roles.d.ts"
      ]
    }
  },
  "references": [{ "path": "../contracts" }, { "path": "../execution-plane" }],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
