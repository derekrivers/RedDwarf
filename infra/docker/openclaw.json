{
  "gateway": {
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:3578",
        "http://localhost:3578"
      ]
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks",
    "defaultSessionKey": "hook:ingress",
    "allowedAgentIds": [
      "reddwarf-coordinator",
      "reddwarf-analyst",
      "reddwarf-arch-reviewer",
      "reddwarf-validator",
      "reddwarf-developer"
    ],
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "hook:",
      "github:issue:"
    ]
  },
  "channels": {
    "discord": {
      "enabled": false,
      "token": "${OPENCLAW_DISCORD_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "commands": {
        "native": true
      }
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "reddwarf-coordinator",
        "default": true,
        "name": "RedDwarf Coordinator",
        "workspace": "/var/lib/reddwarf/workspaces",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-coordinator/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "full",
          "allow": [
            "group:fs",
            "group:sessions",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging",
            "group:nodes"
          ]
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "reddwarf-analyst",
        "name": "RedDwarf Analyst",
        "workspace": "/var/lib/reddwarf/workspaces",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-analyst/agent",
        "model": "anthropic/claude-opus-4-6",
        "tools": {
          "profile": "full",
          "allow": [
            "group:fs",
            "group:web",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "reddwarf-arch-reviewer",
        "name": "RedDwarf Architecture Reviewer",
        "workspace": "/var/lib/reddwarf/workspaces",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-arch-reviewer/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "full",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "reddwarf-validator",
        "name": "RedDwarf Validator",
        "workspace": "/var/lib/reddwarf/workspaces",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-validator/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "full",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:openclaw"
          ],
          "deny": [
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "reddwarf-developer",
        "name": "RedDwarf Developer",
        "workspace": "/var/lib/reddwarf/workspaces",
        "agentDir": "/home/node/.openclaw/agents/reddwarf-developer/agent",
        "model": "anthropic/claude-sonnet-4-6",
        "tools": {
          "profile": "full",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:openclaw"
          ],
          "deny": [
            "group:automation",
            "group:messaging"
          ]
        },
        "sandbox": {
          "mode": "off"
        }
      }
    ]
  }
}
