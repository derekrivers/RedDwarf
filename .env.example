# Canonical env key order for this repo.
# Keep local .env in this same order and add new keys here first.

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
POSTGRES_DB=reddwarf
POSTGRES_USER=reddwarf
POSTGRES_PASSWORD=reddwarf
POSTGRES_HOST_PORT=55532
DATABASE_URL=postgresql://reddwarf:reddwarf@postgres:5432/reddwarf
HOST_DATABASE_URL=postgresql://reddwarf:reddwarf@127.0.0.1:55532/reddwarf
REDDWARF_DB_POOL_MAX=10
REDDWARF_DB_POOL_CONNECTION_TIMEOUT_MS=5000
REDDWARF_DB_POOL_IDLE_TIMEOUT_MS=30000
REDDWARF_DB_POOL_QUERY_TIMEOUT_MS=15000
REDDWARF_DB_POOL_STATEMENT_TIMEOUT_MS=15000
REDDWARF_DB_POOL_MAX_LIFETIME_SECONDS=300
REDDWARF_POLICY_SOURCE_ROOT=../../
REDDWARF_POLICY_ROOT=/opt/reddwarf
REDDWARF_WORKSPACE_ROOT=/var/lib/reddwarf/workspaces
REDDWARF_EVIDENCE_ROOT=/var/lib/reddwarf/evidence
REDDWARF_HOST_WORKSPACE_ROOT=runtime-data/workspaces
REDDWARF_POLICY_PACKAGE_OUTPUT_ROOT=artifacts/policy-packs

# -- API Keys and Secrets ------------------------------------------------------
# GitHub personal access token for issue intake and SCM operations
GITHUB_TOKEN=ghp_your_token_here
# Anthropic API key for LLM planning agent
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OpenClaw webhook hook token - treat as a privileged secret (full-trust ingress)
OPENCLAW_HOOK_TOKEN=replace_with_a_long_random_hook_token
# OpenClaw gateway base URL for HTTP dispatch
OPENCLAW_BASE_URL=http://localhost:3578
# OpenClaw gateway token - used by the Control UI on port 3578
OPENCLAW_GATEWAY_TOKEN=replace_with_a_long_random_gateway_token
# RedDwarf operator API token - required for approvals, runs, blocked, snapshot, and dispatch routes
REDDWARF_OPERATOR_TOKEN=replace_with_a_long_random_operator_token
